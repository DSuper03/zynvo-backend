generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String         @id @default(cuid())
  email           String         @unique
  name            String?
  password        String
  createdAt       DateTime       @default(now())
  profileAvatar   String?
  isVerified      Boolean?       @default(false)
  vToken          String?
  ValidFor        Int?
  expiryToken     Int?
  clubId          String?
  clubName        String?
  collegeName     String         @default("not joined")
  bio             String?        @default("Zynvo Community Fresher")
  course          String?        @default("")
  tags            String[]       @default([])
  year            String?        @default("")
  instagram       String?        @default("")
  linkedin        String?        @default("")
  twitter         String?        @default("")
  phone           String?        @default("")
  clerkId         String?        @unique
  CreatePost      CreatePost[]
  postDownvotes   PostDownvote[]
  postUpvotes     PostUpvote[]
  teamsCreated    Team[]         @relation("TeamCreator")
  teamMemberships TeamMember[]
  club            clubs?         @relation(fields: [clubId], references: [id])
  eventAttended   userEvents[]
}

model clubs {
  id            String             @id @default(uuid())
  name          String
  collegeName   String
  collegeId     String             @unique @default(uuid())
  description   String
  profilePicUrl String?
  clubContact   String             @default("none")
  facultyEmail  String             @default("none")
  founderEmail  String             @unique @default("none")
  requirements  String?            @default("none")
  coremember1   String?            @default("none")
  coremember2   String?            @default("none")
  coremember3   String?            @default("none")
  type          String             @default("General")
  wings         String[]           @default([])
  instagram     String?
  linkedin      String?
  twitter       String?
  createdAt     DateTime           @default(now())
  posts         CreatePost[]
  members       User[]
  announcements clubAnnouncement[]
  events        event[]
}

model CreatePost {
  id          String         @id @default(uuid())
  title       String
  description String
  image       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  published   Boolean        @default(false)
  authorId    String
  collegeId   String?
  clubName    String         @default("zync club")
  collegeName String         @default("zync college")
  author      User           @relation(fields: [authorId], references: [id])
  club        clubs?         @relation(fields: [collegeId], references: [collegeId])
  downvotes   PostDownvote[]
  upvotes     PostUpvote[]
}

model speakers {
  id         Int     @id @default(autoincrement())
  name       String
  email      String  @unique
  eventId    String
  profilePic String?
  about      String
  event      event   @relation(fields: [eventId], references: [id])
}

model event {
  id                   String              @id @default(uuid())
  EventName            String              @unique
  clubId               String
  clubName             String
  description          String
  createdAt            DateTime            @default(now())
  endDate              String?
  eventHeaderImage     String?             @default("none")
  prizes               String              @default("no prizes given")
  EventMode            String              @default("Hybrid")
  EventType            String              @default("general")
  EventUrl             String?             @default("")
  TeamSize             Int                 @default(1)
  Venue                String              @default("")
  applicationStatus    String              @default("open")
  collegeStudentsOnly  Boolean             @default(true)
  contactEmail         String
  contactPhone         String?
  participationFee     Boolean             @default(false)
  posterUrl            String?             @default("")
  startDate            String
  university           String
  Fees                 String?             @default("none")
  Form                 String?
  link1                String?
  link2                String?
  link3                String?
  whatsappLink         String?             @default("")
  qrCodeUrl            String?             @default("")
  isPaid               Boolean             @default(false)
  applicationEndDate   String?             @default("")
  applicationStartDate String?             @default("")
  tagline              String?             @default("")
  teams                Team[]
  TeamMember           TeamMember[]
  club                 clubs               @relation(fields: [clubId], references: [id])
  announcements        eventAnnouncement[]
  galleries            eventGallery[]
  speakers             speakers[]
  attendees            userEvents[]
}

model eventAnnouncement {
  id          String    @id @default(uuid())
  Title       String
  Description String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime?
  eventId     String
  event       event     @relation(fields: [eventId], references: [id])
}

model eventGallery {
  id        String    @id @default(uuid())
  imageUrl  String
  caption   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime?
  eventId   String
  event     event     @relation(fields: [eventId], references: [id])
}

model clubAnnouncement {
  id          String    @id @default(uuid())
  Title       String
  Description String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime?
  clubId      String
  club        clubs     @relation(fields: [clubId], references: [id])
}

model userEvents {
  userId               String
  eventId              String
  joinedAt             DateTime  @default(now())
  uniquePassId         String?   @default("none")
  paymentScreenshotUrl String?   @default("")
  paymentStatus        String    @default("CONFIRMED")
  paymentVerifiedAt    DateTime?
  event                event     @relation(fields: [eventId], references: [id])
  user                 User      @relation(fields: [userId], references: [id])

  @@id([userId, eventId])
}

model PostUpvote {
  id        String     @id @default(uuid())
  postId    String
  userId    String
  createdAt DateTime   @default(now())
  post      CreatePost @relation(fields: [postId], references: [id])
  user      User       @relation(fields: [userId], references: [id])

  @@unique([postId, userId])
}

model PostDownvote {
  id        String     @id @default(uuid())
  postId    String
  userId    String
  createdAt DateTime   @default(now())
  post      CreatePost @relation(fields: [postId], references: [id])
  user      User       @relation(fields: [userId], references: [id])

  @@unique([postId, userId])
}

model Team {
  id          String       @id @default(uuid())
  teamName    String
  teamCode    String       @unique
  eventId     String
  createdById String
  createdAt   DateTime     @default(now())
  createdBy   User         @relation("TeamCreator", fields: [createdById], references: [id])
  event       event        @relation(fields: [eventId], references: [id])
  members     TeamMember[]
}

model TeamMember {
  id       String   @id @default(uuid())
  teamId   String
  userId   String
  role     String   @default("member")
  joinedAt DateTime @default(now())
  eventId  String
  event    event    @relation(fields: [eventId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@unique([teamId, userId])
  @@unique([eventId, userId])
}

enum clubType {
  Technology
  Cultural
  Business
  Social
  Literature
  Design
  General
}
